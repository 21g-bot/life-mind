{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/21g-bot/life-mind/schemas/experience-protocol.schema.json",
  "title": "LIFE-Mind Experience Protocol 0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion", "eventId", "source", "role", "actors", "observation",
    "interpretation", "uncertainty", "privacy"
  ],
  "properties": {
    "schemaVersion": {"const": "0.1"},
    "eventId": {"type": "string", "minLength": 1},
    "eventType": {
      "enum": [
        "conversation", "task_request", "task_success", "task_failure", "guidance",
        "unfair_criticism", "absence", "return", "autonomous_activity", "repair",
        "reflection"
      ]
    },
    "source": {"type": "string", "minLength": 1},
    "role": {"enum": ["user", "agent", "system", "environment", "tool", "other"]},
    "actors": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "observation": {
      "type": "object",
      "required": ["summary"],
      "properties": {"summary": {"type": "string", "minLength": 1}},
      "additionalProperties": true
    },
    "interpretation": {"type": "object"},
    "uncertainty": {"type": "number", "minimum": 0, "maximum": 1},
    "emotionImpact": {
      "type": "object",
      "additionalProperties": {"type": "number", "minimum": -1, "maximum": 1}
    },
    "action": {"type": "object"},
    "outcome": {"type": "object"},
    "privacy": {
      "type": "object",
      "required": ["level", "allowedUses"],
      "properties": {
        "level": {"enum": ["public", "private", "sensitive"]},
        "allowedUses": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        }
      },
      "additionalProperties": true
    },
    "growthCandidates": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    }
  }
}
